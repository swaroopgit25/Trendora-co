@page
@model IndexModel
@using BlazorShared.Authorization
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Trendora";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<section class="trendora-home">
    <section class="trendora-announcement trendora-reveal">
        <div class="trendora-announcement-window">
            <div class="trendora-announcement-track" data-announcement-track>
                <p>Trendora delivers free shipping in India on orders over &#8377;1,500.</p>
                <p>New Trendora edits land every single week.</p>
                <p>Build the full look with tees, bottoms, and jackets in one curated storefront.</p>
            </div>
        </div>
    </section>

    <nav class="trendora-nav trendora-reveal">
        <a class="trendora-logo trendora-logo--nav" asp-page="/Index" aria-label="Trendora home">
            <img src="~/images/brand/trendora-logo.png" alt="Trendora" class="trendora-logo-image" asp-append-version="true" />
        </a>
        <div class="trendora-nav-links">
            <a asp-page="/Index" asp-route-search="new">New In</a>
            <a asp-page="/Index" asp-route-collection="tshirts" asp-route-pageId="0" asp-fragment="products">T-Shirts</a>
            <a asp-page="/Index" asp-route-collection="bottoms" asp-route-pageId="0" asp-fragment="products">Bottoms</a>
            <a asp-page="/Index" asp-route-collection="jackets" asp-route-pageId="0" asp-fragment="products">Jackets</a>
        </div>
        <div class="trendora-nav-actions">
            <a class="trendora-nav-secondary" href="#products">Trending Now</a>
            <a class="trendora-basket-button" asp-page="/Basket/Index">Basket</a>
        </div>
    </nav>

    <section class="trendora-hero trendora-reveal">
        <div class="trendora-hero-copy">
            <p class="trendora-eyebrow">Trendora Spring Edit</p>
            <h1>Own the look before the crowd catches up.</h1>
            <p class="trendora-subtitle">Trendora blends statement outerwear, graphic essentials, and utility silhouettes into one fast-moving storefront built for everyday style rotation.</p>
            <div class="trendora-hero-actions">
                <a asp-page="/Index" asp-route-search="new">Shop New Arrivals</a>
                <a href="#collections">Browse Collections</a>
            </div>
            <div class="trendora-hero-stats">
                <article>
                    <strong>Weekly</strong>
                    <span>fresh drops across the catalog</span>
                </article>
                <article>
                    <strong>&#8377;1,500+</strong>
                    <span>unlocks free shipping in India</span>
                </article>
                <article>
                    <strong>3 core edits</strong>
                    <span>tees, bottoms, and jackets</span>
                </article>
            </div>
        </div>
        <div class="trendora-hero-visual" aria-hidden="true">
            <div class="trendora-hero-note trendora-hero-note--top">New drop every week</div>
            <div class="trendora-hero-note trendora-hero-note--bottom">Streetwear, refined</div>
            <article class="trendora-hero-card trendora-hero-card--feature">
                <span class="trendora-card-kicker">Trend Signal</span>
                <strong>Utility jackets with clean structure and bold everyday energy.</strong>
                <img src="~/images/products/trendora-storm-navy-jacket.png" alt="" />
            </article>
            <article class="trendora-hero-card">
                <img src="~/images/products/trendora-ember-pocket-tee.png" alt="" />
                <div>
                    <span class="trendora-card-kicker">Daily Rotation</span>
                    <strong>Graphic tees that anchor the whole outfit.</strong>
                </div>
            </article>
            <article class="trendora-hero-card">
                <img src="~/images/products/trendora-shadow-cargo-bottoms.png" alt="" />
                <div>
                    <span class="trendora-card-kicker">Street Utility</span>
                    <strong>Cargo silhouettes built for easy movement.</strong>
                </div>
            </article>
        </div>
    </section>

    <div class="trendora-discovery-grid">
        <section class="trendora-search-panel trendora-reveal" id="discover">
            <p class="trendora-section-kicker">Catalog Search</p>
            <h2>Find the right fit in seconds</h2>
            <p class="trendora-section-copy">Search by keyword, narrow by brand, and switch between categories without leaving the front page.</p>
            <form method="get" class="trendora-search">
                <input type="search" name="search" value="@Model.CatalogModel.Search" placeholder="Search by keyword, fit, color, or occasion..." />
                <select name="brandFilterApplied">
                    @foreach (var brand in Model.CatalogModel.Brands ?? Enumerable.Empty<SelectListItem>())
                    {
                        var selected = brand.Value == Model.CatalogModel.BrandFilterApplied?.ToString() ? "selected" : null;
                        <option value="@brand.Value" selected="@selected">@brand.Text</option>
                    }
                </select>
                <select name="typesFilterApplied">
                    @foreach (var type in Model.CatalogModel.Types ?? Enumerable.Empty<SelectListItem>())
                    {
                        var selected = type.Value == Model.CatalogModel.TypesFilterApplied?.ToString() ? "selected" : null;
                        <option value="@type.Value" selected="@selected">@type.Text</option>
                    }
                </select>
                <button type="submit">Search</button>
            </form>
        </section>

        <section class="trendora-style-note trendora-reveal">
            <p class="trendora-section-kicker">Trendora Codes</p>
            <h2>Start with the statement piece, then build around it.</h2>
            <p>Layer a jacket for shape, keep the base clean with a tee, and finish with utility bottoms for a modern everyday silhouette.</p>
            <div class="trendora-style-tags">
                <a asp-page="/Index" asp-route-collection="jackets" asp-route-pageId="0" asp-fragment="products">Shop Jackets</a>
                <a asp-page="/Index" asp-route-collection="tshirts" asp-route-pageId="0" asp-fragment="products">Grab Tees</a>
                <a asp-page="/Index" asp-route-collection="bottoms" asp-route-pageId="0" asp-fragment="products">See Bottoms</a>
            </div>
        </section>
    </div>

    <section class="trendora-collections trendora-reveal" id="collections">
        <header>
            <div>
                <p class="trendora-section-kicker">Shop By Collection</p>
                <h2>Three quick routes into the Trendora edit</h2>
            </div>
            <p>Jump straight into the silhouettes you want while keeping the full catalog one scroll away.</p>
        </header>
        <div class="trendora-collection-grid">
            <a class="trendora-collection-card trendora-collection-card--tshirts" asp-page="/Index" asp-route-collection="tshirts" asp-route-pageId="0" asp-fragment="products">
                <div class="trendora-collection-mosaic" aria-hidden="true">
                    <img class="trendora-collection-image" src="~/images/products/trendora-ember-pocket-tee.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-crimson-classic-tee.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-electric-flame-tee.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-inferno-graphic-tee.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-midnight-polo-shirt.png" alt="" />
                </div>
                <div class="trendora-collection-content">
                    <span>01</span>
                    <strong>T-Shirts</strong>
                    <p>Easy graphic layers and clean staples for daily rotation.</p>
                    <em>Shop collection</em>
                </div>
            </a>
            <a class="trendora-collection-card trendora-collection-card--bottoms" asp-page="/Index" asp-route-collection="bottoms" asp-route-pageId="0" asp-fragment="products">
                <div class="trendora-collection-mosaic" aria-hidden="true">
                    <img class="trendora-collection-image" src="~/images/products/trendora-frost-cargo-bottoms.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-graphite-utility-bottoms.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-mocha-cargo-bottoms.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-shadow-cargo-bottoms.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-mocha-cargo-bottoms.png" alt="" />
                </div>
                <div class="trendora-collection-content">
                    <span>02</span>
                    <strong>Bottoms</strong>
                    <p>Relaxed cargos and clean utility cuts that move with ease.</p>
                    <em>Shop collection</em>
                </div>
            </a>
            <a class="trendora-collection-card trendora-collection-card--jackets" asp-page="/Index" asp-route-collection="jackets" asp-route-pageId="0" asp-fragment="products">
                <div class="trendora-collection-mosaic" aria-hidden="true">
                    <img class="trendora-collection-image" src="~/images/products/trendora-obsidian-hooded-jacket.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-olive-ridge-jacket.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-storm-navy-jacket.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-olive-ridge-jacket.png" alt="" />
                    <img class="trendora-collection-image" src="~/images/products/trendora-storm-navy-jacket.png" alt="" />
                </div>
                <div class="trendora-collection-content">
                    <span>03</span>
                    <strong>Jackets</strong>
                    <p>Structured outer layers that add shape, edge, and color.</p>
                    <em>Shop collection</em>
                </div>
            </a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="trendora-status-message trendora-reveal">@Model.StatusMessage</section>
    }

    @if (isAuthenticated)
    {
        <section class="trendora-manage-products trendora-reveal">
            <p class="trendora-section-kicker">Studio Control</p>
            <h2>Add a new product to Trendora</h2>
            <p class="trendora-section-copy">Create a fresh catalog item with a name, price, category, and optional image path.</p>
            <form method="post" asp-page-handler="CreateProduct" class="trendora-manage-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input asp-for="NewProduct.Name" placeholder="Product name" />
                <input asp-for="NewProduct.Price" type="number" min="0.01" step="0.01" placeholder="Price" />
                <select asp-for="NewProduct.CatalogTypeId">
                    <option value="">Choose category</option>
                    @foreach (var type in Model.AvailableTypes)
                    {
                        <option value="@type.Value">@type.Text</option>
                    }
                </select>
                <select asp-for="NewProduct.CatalogBrandId">
                    <option value="">Choose brand</option>
                    @foreach (var brand in Model.AvailableBrands)
                    {
                        <option value="@brand.Value">@brand.Text</option>
                    }
                </select>
                <input asp-for="NewProduct.Description" placeholder="Description (optional)" />
                <input asp-for="NewProduct.PictureUri" placeholder="Image path (optional)" />
                <button type="submit">Add Product</button>
            </form>
        </section>
    }

    <section id="products" class="trendora-products trendora-reveal">
        <header class="trendora-products-header">
            <div>
                <p class="trendora-section-kicker">Trending Now</p>
                <h2>Featured products from the current Trendora feed</h2>
            </div>
            <p>Add pieces to basket directly from this front-page rail.</p>
        </header>
        @if (Model.CatalogModel.CatalogItems.Any())
        {
            <partial name="_pagination" for="CatalogModel.PaginationInfo" />
            <div class="trendora-rail-controls">
                <button type="button" data-scroll-dir="-1" aria-label="Scroll products left">&#8592;</button>
                <button type="button" data-scroll-dir="1" aria-label="Scroll products right">&#8594;</button>
            </div>
            <div class="trendora-product-scroller" data-product-scroller>
                @foreach (var catalogItem in Model.CatalogModel.CatalogItems)
                {
                    <article class="trendora-product-slide">
                        <partial name="_product" for="@catalogItem" />
                    </article>
                }
            </div>
            <partial name="_pagination" for="CatalogModel.PaginationInfo" />
        }
        else
        {
            <div class="trendora-no-results">No Trendora products matched your search.</div>
        }
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function updateSelectedOptions(form) {
                const hiddenInput = form.querySelector(".selected-options-json");
                if (!hiddenInput) return;

                const selected = Array.from(form.querySelectorAll(".option-radio:checked")).map((option) => ({
                    productOptionId: parseInt(option.dataset.optionId || "0"),
                    type: option.dataset.optionType || "",
                    value: option.value || "",
                    displayName: option.dataset.displayName || "",
                    additionalPrice: parseFloat(option.dataset.additionalPrice || "0")
                }));

                hiddenInput.value = JSON.stringify(selected);
            }

            document.addEventListener("change", (event) => {
                if (!event.target.classList.contains("option-radio")) return;
                const form = event.target.closest(".product-form");
                if (form) updateSelectedOptions(form);
            });

            document.addEventListener("submit", (event) => {
                const form = event.target.closest(".product-form");
                if (form) updateSelectedOptions(form);
            });

            const revealElements = document.querySelectorAll(".trendora-reveal");
            if ("IntersectionObserver" in window) {
                const revealObserver = new IntersectionObserver((entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-visible");
                            revealObserver.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.12 });

                revealElements.forEach((element) => revealObserver.observe(element));
            } else {
                revealElements.forEach((element) => element.classList.add("is-visible"));
            }

            const announcementTrack = document.querySelector("[data-announcement-track]");
            if (announcementTrack) {
                const total = announcementTrack.children.length;
                let index = 0;

                setInterval(() => {
                    index = (index + 1) % total;
                    announcementTrack.style.transform = `translateY(-${index * 100}%)`;
                }, 3600);
            }

            const productScroller = document.querySelector("[data-product-scroller]");
            if (productScroller) {
                document.querySelectorAll("[data-scroll-dir]").forEach((button) => {
                    button.addEventListener("click", () => {
                        const direction = parseInt(button.getAttribute("data-scroll-dir") || "1", 10);
                        productScroller.scrollBy({
                            left: direction * productScroller.clientWidth * 0.85,
                            behavior: "smooth"
                        });
                    });
                });
            }
        })();
    </script>
}
